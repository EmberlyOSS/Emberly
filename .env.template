# Database (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/emberly?schema=public"

# Authentication (NextAuth.js)
# Canonical URL of your site
NEXTAUTH_URL="http://localhost:3000"
# Secret used to encrypt session tokens (generate with `openssl rand -base64 32`)
NEXTAUTH_SECRET=""

# Multi-domain authentication support
# List of trusted origins for CSRF protection (comma-separated)
# Example: "https://emberly.site,https://embrly.ca"
# Note: For unrelated domains (different registrable domains), each domain
# will have its own session cookie. To share sessions, you'll need a shared backend.
NEXTAUTH_TRUSTED_ORIGINS=""

# Optional: share session cookie across subdomains of a single registrable domain
# Example: ".emberly.site" (note the leading dot) for *.emberly.site
# WARNING: Only use when all domains are subdomains of the same registrable domain
NEXTAUTH_COOKIE_DOMAIN=""
NEXTAUTH_COOKIE_NAME="next-auth.session-token"

# App URLs
# Used for constructing absolute links in emails/metadata
APP_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Redis (Caching & Events)
REDIS_URL="redis://localhost:6379"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="Emberly <noreply@emberly.site>"

# Storage (AWS S3 Compatible)
# Required if using 's3' provider in config
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="emberly-uploads"
# Optional: S3 Endpoint for custom providers (e.g. MinIO, R2)
# AWS_ENDPOINT=""

# Cloudflare (Domains & DNS)
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ZONE_ID=""

# GitHub
GITHUB_ORG="EmberlyOSS"
GITHUB_PAT=""

# OAuth (Social Account Linking)
# GitHub OAuth App credentials
GITHUB_OAUTH_CLIENT_ID=""
GITHUB_OAUTH_CLIENT_SECRET=""

# Discord OAuth App credentials
DISCORD_OAUTH_CLIENT_ID=""
DISCORD_OAUTH_CLIENT_SECRET=""

# Discord Bot (for booster verification)
DISCORD_BOT_TOKEN=""
DISCORD_SERVER_ID="871204257649557604"

# Optional: OCR
# TESSERACT_LANG_PATH=""
