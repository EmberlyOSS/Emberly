# Database (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/emberly?schema=public"

# Authentication (NextAuth.js)
# Canonical URL of your site
NEXTAUTH_URL="http://localhost:3000"
# Secret used to encrypt session tokens (generate with `openssl rand -base64 32`)
NEXTAUTH_SECRET=""

# App URLs
# Used for constructing absolute links in emails/metadata
APP_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Redis (Caching & Events)
REDIS_URL="redis://localhost:6379"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="Emberly <noreply@emberly.site>"

# Storage (AWS S3 Compatible)
# Required if using 's3' provider in config
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="emberly-uploads"
# Optional: S3 Endpoint for custom providers (e.g. MinIO, R2)
# AWS_ENDPOINT=""

# Cloudflare (Domains & DNS)
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ZONE_ID=""

# Optional: OCR
# TESSERACT_LANG_PATH=""
